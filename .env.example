# URL del endpoint externo de farmacias de turno (server-side)
PHARMACIES_ENDPOINT=https://www.barilochense.com/js/farmacias2024.php?limit=3

# Google Maps Platform API key (client-side)
# Habilitar en Google Cloud Console:
#   - Maps JavaScript API
#   - Places API
#   - Directions API
PUBLIC_GOOGLE_MAPS_API_KEY=your_api_key_here

# Google Maps Map ID (creado en Google Maps Platform → Map styles)
PUBLIC_GOOGLE_MAP_ID=your_map_id_here
